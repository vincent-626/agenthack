# agenthack.yaml — copy to agenthack.yaml and customize

defaults:
  depth: standard           # fast | standard | deep
  teams: 10                 # number of parallel teams
  top_k: 3                  # number of winners to build
  checkpoint_after_scout: false
  checkpoint_after_judging: false

models:
  scout: claude-sonnet-4-6
  analyst: claude-sonnet-4-6
  strategist: claude-sonnet-4-6
  judges: claude-sonnet-4-6

judge_weights:
  market: 0.25
  technical: 0.25
  user: 0.25
  vc: 0.25

budget:
  max_tokens_per_team: 200000
  max_tokens_per_build: 500000
  max_total_cost: 50.00

scraping:
  firecrawl_api_key: ${FIRECRAWL_API_KEY}
  max_pages_per_team: 30
  max_pages_scout: 100
